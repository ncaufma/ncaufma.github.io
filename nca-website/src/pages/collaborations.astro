---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const collabs = await getCollection('collaborations');

const groups: Record<string, { label: string; items: typeof collabs }> = {
  university:         { label: 'Universities & Research Institutes', items: [] },
  company:            { label: 'Companies & Industry', items: [] },
  government:         { label: 'Government Agencies', items: [] },
  'research-institute': { label: 'Research Institutes', items: [] },
};

collabs.forEach(c => {
  const key = c.data.type;
  if (groups[key]) groups[key].items.push(c);
  else groups.university.items.push(c);
});
---
<BaseLayout title="Partners" description="NCA-UFMA collaborators and partners: national and international universities, companies, and government agencies.">

  <div class="page-hero">
    <div class="container">
      <h1 class="display-lg">Partners & Collaborators</h1>
      <p class="page-lead">A collaboration network spanning universities, industrial companies, and government agencies in Brazil and abroad.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {Object.entries(groups).map(([key, group]) =>
        group.items.length > 0 && (
          <div class="collab-group reveal" key={key}>
            <h2 class="group-title">{group.label}</h2>
            <div class="collab-grid">
              {group.items
                .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99) || a.data.name.localeCompare(b.data.name))
                .map(c => (
                  <a
                    href={c.data.url && !c.data.url.startsWith('[REQUIRED') ? c.data.url : undefined}
                    target={c.data.url && !c.data.url.startsWith('[REQUIRED') ? '_blank' : undefined}
                    rel="noopener noreferrer"
                    class:list={['collab-card', { 'no-link': !c.data.url || c.data.url.startsWith('[REQUIRED') }]}
                  >
                    <div class="collab-logo-wrap">
                      {c.data.logo && !c.data.logo.startsWith('[REQUIRED') ? (
                        <img
                          src={`/assets/collaborations/${c.data.logo}`}
                          alt={`Logo ${c.data.name}`}
                          loading="lazy"
                          class="collab-logo"
                        />
                      ) : (
                        <div class="collab-initials">
                          {c.data.name.split(/[\s/]/).filter(Boolean).map(w => w[0]).slice(0, 3).join('')}
                        </div>
                      )}
                    </div>
                    <div class="collab-info">
                      <span class="collab-name">{c.data.name}</span>
                      <span class="collab-country">{c.data.country}</span>
                    </div>
                  </a>
                ))
              }
            </div>
          </div>
        )
      )}
    </div>
  </section>

</BaseLayout>

<style>
.page-hero { padding-block: var(--space-8) var(--space-10); background: var(--color-bg-alt); }
.page-lead { font-size: 1.125rem; color: var(--color-text-muted); max-width: 54ch; margin-top: var(--space-4); }

.collab-group { margin-bottom: var(--space-10); }
.group-title {
  font-size: 1.1rem; font-weight: 700;
  color: var(--color-text-muted);
  letter-spacing: -0.01em;
  padding-bottom: var(--space-4);
  border-bottom: 1.5px solid var(--color-border);
  margin-bottom: var(--space-6);
}

.collab-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: var(--space-4);
}

.collab-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-5);
  background: var(--color-bg);
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-lg);
  text-decoration: none;
  color: inherit;
  text-align: center;
  transition: all var(--transition-base);
}
.collab-card:not(.no-link):hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-sm);
  transform: translateY(-3px);
}
.collab-card.no-link { cursor: default; }

.collab-logo-wrap {
  width: 80px; height: 60px;
  display: flex; align-items: center; justify-content: center;
}
.collab-logo {
  max-width: 80px; max-height: 60px;
  width: auto; height: auto;
  object-fit: contain;
  filter: grayscale(30%);
  transition: filter var(--transition-base);
}
.collab-card:hover .collab-logo { filter: none; }

.collab-initials {
  width: 64px; height: 64px;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--color-secondary), var(--color-neutral));
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 1.1rem; font-weight: 800;
  letter-spacing: -0.02em;
}

.collab-info { display: flex; flex-direction: column; gap: var(--space-1); }
.collab-name { font-size: 0.875rem; font-weight: 600; color: var(--color-text); line-height: 1.3; }
.collab-country { font-size: 0.75rem; color: var(--color-text-muted); }
</style>
