---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const page     = await getEntry('pages', 'about');
const settings = await getEntry('settings', 'site');
const { Content } = await page!.render();

const address   = settings?.data.address ?? '';
const mapsEmbed = settings?.data.googleMapsEmbed ?? '';
const hasAddress = address   && !address.startsWith('[REQUIRED');
const hasMap     = mapsEmbed && !mapsEmbed.startsWith('[REQUIRED');
---
<BaseLayout title="About NCA-UFMA" description="History, missions and infrastructure.">

  <div class="page-hero">
    <div class="container">
      <h1 class="display-lg">About NCA-UFMA</h1>
      <p class="page-lead">A research and development center focused on high-impact solutions for industry, government, and society.</p>
    </div>
  </div>

  <section class="section">
    <div class="container about-body">
      <div class="prose">
        <Content />
      </div>

      {hasMap && (
        <div class="map-block">
          <div class="map-wrap">
            <iframe
              src={mapsEmbed}
              width="100%"
              height="360"
              style="border:0; border-radius: 8px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="NCA-UFMA Location"
            ></iframe>
          </div>
        </div>
      )}
    </div>
  </section>

</BaseLayout>

<style>
.page-hero { padding-block: var(--space-8) var(--space-10); background: var(--color-bg-alt); }
.page-lead { font-size: 1.125rem; color: var(--color-text-muted); max-width: 58ch; margin-top: var(--space-4); line-height: 1.7; }

.about-body {
  max-width: 820px;
  margin: 0 auto;
}

.map-block { margin-top: var(--space-8); }
.map-wrap { border-radius: var(--radius-md); overflow: hidden; }
</style>
