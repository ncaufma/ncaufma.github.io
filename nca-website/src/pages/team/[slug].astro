---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const team = await getCollection('team');
  return team.map(member => ({ params: { slug: member.slug }, props: { member } }));
}

const { member } = Astro.props;
const { data } = member;
const { Content } = await member.render();

const allProjects = await getCollection('projects');
const memberProjects = allProjects.filter(p => p.data.members?.includes(member.slug));

// ── Scholar publications ───────────────────────────────────────────
// Fetched at build time by scripts/fetch-scholar-members.mjs and stored
// as src/data/member-publications/{slug}.json. The page works fine even
// when the file is missing (publications section is simply hidden).
type ScholarPub = {
  title: string;
  authors: string;
  venue: string;
  year?: number;
  type: 'journal' | 'conference' | 'book-chapter' | 'thesis' | 'preprint' | 'other';
  link: string;
};
type ScholarPayload = {
  slug: string;
  name: string;
  sourceUrl: string;
  fetchedAt: string;
  count: number;
  publications: ScholarPub[];
};

const pubFiles = import.meta.glob<ScholarPayload>(
  '../../data/member-publications/*.json',
  { eager: true, import: 'default' },
);
const pubKey = Object.keys(pubFiles).find(k => k.endsWith(`/${member.slug}.json`));
const scholarPayload: ScholarPayload | null = pubKey ? pubFiles[pubKey] : null;
const scholarPubs: ScholarPub[] = scholarPayload?.publications ?? [];

const typeLabel: Record<string, string> = {
  journal: 'Journal',
  conference: 'Conference',
  'book-chapter': 'Book Chapter',
  thesis: 'Thesis/Dissertation',
  preprint: 'Preprint',
  other: 'Other',
};

const placeholder = (val?: string) => !val || val.startsWith('[REQUIRED');

const hasOrcid    = !placeholder(data.orcid);
const hasScholar  = !placeholder(data.googleScholar);
const hasRG       = !placeholder(data.researchgate);
const hasLinkedIn = !placeholder(data.linkedin);
const hasInsta    = !placeholder(data.instagram);
const hasTwitter  = !placeholder(data.twitter);

const instagramUrl = hasInsta
  ? (data.instagram!.startsWith('http') ? data.instagram : `https://instagram.com/${data.instagram!.replace(/^@/, '')}`)
  : null;
const twitterUrl = hasTwitter
  ? (data.twitter!.startsWith('http') ? data.twitter : `https://twitter.com/${data.twitter!.replace(/^@/, '')}`)
  : null;
---
<BaseLayout title={data.name} description={placeholder(data.bio) ? `NCA-UFMA researcher: ${data.name}` : data.bio}>

  <div class="page-hero">
    <div class="container profile-hero">
      <div class="profile-photo-wrap">
        {!placeholder(data.photo) ? (
          <img src={`/assets/team/${data.photo}`} alt={`Photo of ${data.name}`} class="profile-photo" width="160" height="160" />
        ) : (
          <div class="profile-initials">
            {data.name.split(' ').map((w: string) => w[0]).filter(Boolean).slice(0, 2).join('')}
          </div>
        )}
      </div>

      <div class="profile-meta">
        <span class="profile-role">{data.role}</span>
        <h1 class="profile-name">{data.name}</h1>
        {!placeholder(data.title) && <p class="profile-title">{data.title}</p>}
        {!placeholder(data.email) && (
          <a href={`mailto:${data.email}`} class="profile-email">{data.email}</a>
        )}

        <!-- Social links -->
        <div class="profile-socials">
          {hasOrcid    && <a href={`https://orcid.org/${data.orcid}`} target="_blank" rel="noopener noreferrer" class="social-btn" title="ORCID">ORCID</a>}
          {hasScholar  && <a href={data.googleScholar} target="_blank" rel="noopener noreferrer" class="social-btn" title="Google Scholar">Scholar</a>}
          {hasRG       && <a href={data.researchgate} target="_blank" rel="noopener noreferrer" class="social-btn" title="ResearchGate">ResearchGate</a>}
          {hasLinkedIn && <a href={data.linkedin} target="_blank" rel="noopener noreferrer" class="social-btn" title="LinkedIn">LinkedIn</a>}
          {instagramUrl && <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="social-btn" title="Instagram">Instagram</a>}
          {twitterUrl   && <a href={twitterUrl} target="_blank" rel="noopener noreferrer" class="social-btn" title="Twitter / X">Twitter</a>}
        </div>
      </div>
    </div>
  </div>

  <div class="container profile-body">

    <!-- Research lines -->
    {data.researchLines.length > 0 && !data.researchLines[0].startsWith('[REQUIRED') && (
      <section class="profile-section">
        <h2>Research Lines</h2>
        <div class="research-lines">
          {data.researchLines.map((line: string) => (
            <span class="tag tag-secondary">{line}</span>
          ))}
        </div>
      </section>
    )}

    <!-- Bio / content -->
    <section class="profile-section">
      <h2>About</h2>
      {!placeholder(data.bio) && <p class="profile-bio">{data.bio}</p>}
      <div class="prose">
        <Content />
      </div>
    </section>

    <!-- Highlights -->
    {data.highlights.length > 0 && !data.highlights[0].startsWith('[REQUIRED') && (
      <section class="profile-section">
        <h2>Highlights</h2>
        <ul class="profile-highlights">
          {data.highlights.map((h: string) => <li>{h}</li>)}
        </ul>
      </section>
    )}

    <!-- Publications (auto-fetched from Google Scholar) -->
    {scholarPubs.length > 0 && (
      <section class="profile-section">
        <div class="pubs-header">
          <h2>Publications</h2>
          <span class="pubs-count">{scholarPubs.length}</span>
        </div>

        <ul class="member-pub-list">
          {scholarPubs.map((p) => (
            <li class="member-pub-item">
              <div class="member-pub-meta">
                <span class:list={['tag', p.type === 'journal' ? 'tag-primary' : p.type === 'conference' ? 'tag-secondary' : 'tag-neutral']}>
                  {typeLabel[p.type] ?? p.type}
                </span>
                {p.year && <span class="member-pub-year">{p.year}</span>}
              </div>
              <div class="member-pub-body">
                <h3 class="member-pub-title">
                  {p.link ? (
                    <a href={p.link} target="_blank" rel="noopener noreferrer">{p.title}</a>
                  ) : (
                    p.title
                  )}
                </h3>
                {p.authors && <p class="member-pub-authors">{p.authors}</p>}
                {p.venue   && <p class="member-pub-venue">{p.venue}</p>}
              </div>
            </li>
          ))}
        </ul>

        <p class="pubs-source">
          Source: <a href={scholarPayload!.sourceUrl} target="_blank" rel="noopener noreferrer">Google Scholar</a>.
          Updated automatically on every site build.
        </p>
      </section>
    )}

    <!-- Associated Projects (moved from sidebar) -->
    {memberProjects.length > 0 && (
      <section class="profile-section">
        <h2>Associated Projects</h2>
        <ul class="projects-list">
          {memberProjects.map(p => (
            <li>
              <a href={`/projects/${p.slug}`} class="project-row">
                <span class="project-row-title">{p.data.title}</span>
                <span class:list={['tag', p.data.status === 'active' ? 'tag-accent' : 'tag-neutral']} style="font-size:0.7rem">
                  {p.data.status === 'active' ? 'Active' : 'Concluded'}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <div class="back-link-wrap">
      <a href="/team" class="btn btn-ghost btn-sm">← Back to team</a>
    </div>
  </div>

</BaseLayout>

<style>
.page-hero {
  background: var(--color-bg-alt);
  padding-bottom: var(--space-8);
}

.profile-hero {
  display: flex;
  gap: var(--space-8);
  align-items: flex-start;
  padding-top: var(--space-8);
}

.profile-photo-wrap {
  width: 160px; height: 160px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 4px solid var(--color-bg);
  box-shadow: var(--shadow-md);
}
.profile-photo { width: 100%; height: 100%; object-fit: cover; }
.profile-initials {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, var(--color-secondary), var(--color-primary));
  color: #fff;
  font-family: var(--font-display);
  font-size: 3rem;
  font-weight: 800;
}

.profile-meta { display: flex; flex-direction: column; gap: var(--space-2); }
.profile-role {
  font-size: 0.7rem; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--color-accent);
}
.profile-name { font-size: clamp(1.75rem, 4vw, 3rem); }
.profile-title { font-size: 1rem; color: var(--color-text-muted); }
.profile-email {
  font-size: 0.9rem; color: var(--color-primary);
  text-decoration: none;
}
.profile-email:hover { text-decoration: underline; }

.profile-socials { display: flex; gap: var(--space-2); flex-wrap: wrap; margin-top: var(--space-2); }
.social-btn {
  display: inline-flex;
  align-items: center;
  padding: 0.3rem 0.75rem;
  border-radius: var(--radius-full);
  border: 1.5px solid var(--color-border);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: all var(--transition-fast);
}
.social-btn:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
  background: rgba(35,70,229,0.05);
}

.profile-body {
  max-width: 820px;
  margin: 0 auto;
  padding-block: var(--space-8);
}

.profile-section { margin-bottom: var(--space-8); }
.profile-section h2 {
  font-size: 1.15rem;
  margin-bottom: var(--space-4);
  padding-bottom: var(--space-2);
  border-bottom: 1.5px solid var(--color-border);
}

.research-lines { display: flex; flex-wrap: wrap; gap: var(--space-2); }
.profile-bio { font-size: 1.0625rem; line-height: 1.75; color: var(--color-text); margin-bottom: var(--space-4); }

.profile-highlights { padding-left: 1.25rem; display: flex; flex-direction: column; gap: var(--space-2); }
.profile-highlights li { font-size: 0.9375rem; color: var(--color-text); list-style: disc; }

.pubs-header { display: flex; align-items: baseline; justify-content: space-between; }
.pubs-count {
  font-size: 0.75rem; font-weight: 700;
  color: var(--color-text-muted);
  background: var(--color-bg-alt);
  padding: 0.15rem 0.6rem;
  border-radius: var(--radius-full);
}
.pubs-source {
  margin-top: var(--space-3);
  font-size: 0.75rem;
  color: var(--color-text-muted);
  font-style: italic;
}
.pubs-source a { color: var(--color-primary); text-decoration: none; }
.pubs-source a:hover { text-decoration: underline; }

.member-pub-list { list-style: none; display: flex; flex-direction: column; gap: 0; }
.member-pub-item {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: var(--space-4);
  padding: var(--space-4) 0;
  border-bottom: 1px solid var(--color-border);
  align-items: start;
}
.member-pub-item:last-child { border-bottom: none; }
.member-pub-meta { display: flex; flex-direction: column; gap: var(--space-1); }
.member-pub-year { font-size: 0.8125rem; font-weight: 700; color: var(--color-text-muted); }
.member-pub-body { display: flex; flex-direction: column; gap: var(--space-1); }
.member-pub-title { font-size: 0.9375rem; font-weight: 700; line-height: 1.4; }
.member-pub-title a { color: var(--color-primary); text-decoration: none; }
.member-pub-title a:hover { text-decoration: underline; }
.member-pub-authors { font-size: 0.8125rem; color: var(--color-text-muted); }
.member-pub-venue   { font-size: 0.8125rem; color: var(--color-text); font-style: italic; }

@media (max-width: 640px) {
  .member-pub-item { grid-template-columns: 1fr; gap: var(--space-2); }
  .member-pub-meta { flex-direction: row; align-items: center; gap: var(--space-2); }
}

.projects-list { display: flex; flex-direction: column; gap: var(--space-2); list-style: none; }
.project-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-3);
  text-decoration: none;
  color: inherit;
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-md);
  border: 1.5px solid var(--color-border);
  background: var(--color-bg);
  transition: all var(--transition-fast);
}
.project-row:hover { border-color: var(--color-primary); background: var(--color-bg-alt); }
.project-row-title { font-size: 0.95rem; font-weight: 600; color: var(--color-text); }

.back-link-wrap { margin-top: var(--space-8); }

@media (max-width: 768px) {
  .profile-hero { flex-direction: column; }
}
</style>
