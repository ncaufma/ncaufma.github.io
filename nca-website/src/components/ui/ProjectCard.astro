---
interface Props {
  title: string;
  partner?: string;
  status: string;
  description: string;
  researchArea?: string;
  highlights?: string[];
  slug: string;
  featured?: boolean;
  index?: number;
}
const { title, partner, status, description, highlights = [], slug, featured = false, index = 0 } = Astro.props;
const statusLabel: Record<string, string> = { active: 'Active', concluded: 'Concluded', paused: 'Paused' };
const statusClass: Record<string, string> = { active: 'tag-accent', concluded: 'tag-neutral', paused: 'tag-secondary' };
---
<article class:list={['project-card reveal', { 'project-card--featured': featured }]} style={`animation-delay: ${index * 0.08}s`}>
  <header class="project-card-header">
    <div class="project-card-meta">
      <span class:list={['tag', statusClass[status] ?? 'tag-neutral']}>{statusLabel[status] ?? status}</span>
      {featured && <span class="tag tag-primary">Featured</span>}
    </div>
    <h3 class="project-title">{title}</h3>
    {partner && <p class="project-partner">{partner}</p>}
  </header>

  <p class="project-description">{description}</p>

  {highlights.length > 0 && (
    <ul class="project-highlights">
      {highlights.slice(0, 3).map(h => (
        <li>{h}</li>
      ))}
    </ul>
  )}

  <a href={`/projects/${slug}`} class="project-link">See details →</a>
</article>

<style>
.project-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding: var(--space-6);
  background: var(--color-bg);
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-lg);
  transition: all var(--transition-base);
}
.project-card:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-md);
  transform: translateY(-3px);
}
.project-card--featured {
  border-color: var(--color-accent);
  background: linear-gradient(135deg, rgba(200,146,42,0.03), var(--color-bg));
}

.project-card-header { display: flex; flex-direction: column; gap: var(--space-2); }
.project-card-meta { display: flex; gap: var(--space-2); flex-wrap: wrap; }

.project-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.3;
}
.project-partner {
  font-size: 0.8125rem;
  color: var(--color-accent);
  font-weight: 600;
}

.project-description {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.65;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.project-highlights {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  padding: var(--space-3) var(--space-4);
  background: var(--color-bg-alt);
  border-radius: var(--radius-md);
  border-left: 3px solid var(--color-primary);
  list-style: none;
}
.project-highlights li {
  font-size: 0.8125rem;
  color: var(--color-text-muted);
  display: flex;
  gap: var(--space-2);
  align-items: flex-start;
}
.project-highlights li::before {
  content: '✓';
  color: var(--color-primary);
  font-weight: 700;
  flex-shrink: 0;
}

.project-link {
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-primary);
  text-decoration: none;
  margin-top: auto;
  transition: gap var(--transition-fast);
  display: inline-flex;
  gap: var(--space-1);
}
.project-link:hover { gap: var(--space-2); }
</style>
