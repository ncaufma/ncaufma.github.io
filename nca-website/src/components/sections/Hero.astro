---
import ColorBar from '../ui/ColorBar.astro';
---
<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-geo geo-1"></div>
    <div class="hero-geo geo-2"></div>
    <div class="hero-geo geo-3"></div>
    <div class="hero-geo geo-4"></div>
  </div>

  <div class="container hero-inner">
    <div class="hero-content">
      <h1 class="hero-title animate-fade-up stagger-1">
        Applied Computer Group
      </h1>
      <h1 class="hero-title animate-fade-up stagger-1">
        NCA-UFMA
      </h1>


      <p class="hero-tagline tagline-italic animate-fade-up stagger-2">
        Applying computing for the development of society, developing innovative solutions.
      </p>

      <p class="hero-lead animate-fade-up stagger-3">
        <strong>Applied Computer Group NCA-UFMA</strong> is a research group at the
        <a href="https://www.ufma.br" target="_blank" rel="noopener noreferrer" class="hero-link">
          Federal University of Maranhão, Brazil
        </a>
        dedicated to advancing Artificial Intelligence, Computer Vision, Medical Imaging,
        Virtual Reality, Natural Language Processing, and Optimization to create
        high-impact solutions for society.
      

      
    </div>
  </div>

  <ColorBar class="hero-bar" />
</section>

<style>
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--color-bg);
}

.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}
.hero-geo {
  position: absolute;
  border-radius: 2px;
  opacity: 0.06;
}
.geo-1 {
  width: 420px; height: 420px;
  background: var(--color-primary);
  top: -80px; right: -80px;
  transform: rotate(25deg);
  border-radius: var(--radius-xl);
}
.geo-2 {
  width: 280px; height: 280px;
  background: var(--color-secondary);
  bottom: 40px; right: 180px;
  transform: rotate(-15deg);
  border-radius: var(--radius-lg);
}
.geo-3 {
  width: 160px; height: 160px;
  background: var(--color-accent);
  top: 120px; right: 320px;
  transform: rotate(40deg);
  border-radius: var(--radius-md);
}
.geo-4 {
  width: 90px; height: 90px;
  background: var(--color-tagline);
  top: 60px; left: 40%;
  transform: rotate(12deg);
  border-radius: var(--radius-md);
}



.hero-content { max-width: 820px; }

.hero-eyebrow { margin-bottom: var(--space-6); }

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.75rem, 6.5vw, 5.25rem);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: var(--space-5);
  color: var(--color-primary);
}

.hero-tagline {
  font-size: clamp(1.125rem, 2vw, 1.5rem);
  line-height: 1.35;
  margin-bottom: var(--space-6);
  max-width: 58ch;
}

.hero-lead {
  font-size: clamp(1rem, 1.4vw, 1.125rem);
  color: var(--color-text);
  line-height: 1.7;
  margin-bottom: var(--space-8);
  max-width: 62ch;
}
.hero-lead strong {
  font-weight: 700;
  color: var(--color-text);
}
.hero-link {
  color: var(--color-primary);
  font-weight: 600;
  text-decoration: none;
  border-bottom: 1.5px solid transparent;
  transition: border-color var(--transition-fast);
}
.hero-link:hover {
  border-bottom-color: var(--color-primary);
}

.hero-ctas {
  display: flex;
  gap: var(--space-3);
  flex-wrap: wrap;
}

.hero-bar { margin-top: auto; }

@media (max-width: 600px) {
  .hero-ctas { gap: var(--space-2); }
  .btn { font-size: 0.875rem; padding: 0.5rem 1rem; }
}
.hero-inner {
  display: flex;
  align-items: center;
  padding-block: var(--space-8);
}
</style>
