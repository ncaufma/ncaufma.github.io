# NCA-UFMA Website — Environment Variables
# Copy this file to .env and fill in values as needed.
# Never commit .env to version control.

# ── Google Scholar ────────────────────────────────────────────
# URL of the Google Scholar group/author profile to import publications from.
# Example: https://scholar.google.com/citations?user=XXXXXXX&sortby=pubdate
SCHOLAR_URL=

# ── Instagram Basic Display API ───────────────────────────────
# Long-lived access token obtained from the Instagram Basic Display API.
# Expires after 60 days — re-run deploy or update:scholar to refresh.
# Setup guide: https://developers.facebook.com/docs/instagram-basic-display-api
INSTAGRAM_TOKEN=

# ── LinkedIn ──────────────────────────────────────────────────
# LinkedIn API access token (optional — manual posting recommended)
LINKEDIN_TOKEN=

# ── Build ─────────────────────────────────────────────────────
# Override the production site URL (defaults to astro.config.mjs value)
SITE=https://ncaufma.github.io
